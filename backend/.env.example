# =========================================================
# AI Career Toolkit — Backend Environment Variables (example)
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# =========================================================

# --- App ---
APP_NAME="AI Career Toolkit API"
APP_ENV=development                # development | staging | production
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
POSTGRES_USER=career_toolkit_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=career_toolkit
# Full async URL is assembled from the above at runtime, but can be overridden:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# --- Redis (optional caching layer) ---
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT (wired in the Auth module) ---
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- File uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# --- Logging ---
LOG_LEVEL=INFO

# --- ATS Scoring weights (Module 3) ---
# Relative importance of each scoring category — must sum to 1.0
# (auto-normalized with a warning if they don't).
ATS_WEIGHT_KEYWORD_MATCH=0.30
ATS_WEIGHT_FORMATTING=0.15
ATS_WEIGHT_SECTION_COMPLETENESS=0.20
ATS_WEIGHT_ACHIEVEMENTS=0.20
ATS_WEIGHT_PARSEABILITY=0.15

# --- GitHub Profile Analysis (Module 4) ---
# Optional but recommended: raises the GitHub REST API rate limit from
# 60/hr (unauthenticated) to 5,000/hr. Needs no scopes — public data only.
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_TIMEOUT_SECONDS=10.0
GITHUB_TOP_REPOS_LIMIT=6
GITHUB_README_ANALYSIS_LIMIT=5
GITHUB_ANALYSIS_CACHE_TTL_SECONDS=900

# Relative importance of each scoring category — must sum to 1.0
# (auto-normalized with a warning if they don't).
GITHUB_WEIGHT_REPOSITORY_PORTFOLIO=0.25
GITHUB_WEIGHT_TOP_REPOSITORIES=0.20
GITHUB_WEIGHT_README_QUALITY=0.30
GITHUB_WEIGHT_ACTIVITY=0.25

# --- LinkedIn Optimizer (Module 6: scoring engine) ---
# Relative importance of each scoring category — must sum to 1.0
# (auto-normalized with a warning if they don't).
LINKEDIN_WEIGHT_HEADLINE=0.10
LINKEDIN_WEIGHT_ABOUT=0.15
LINKEDIN_WEIGHT_EXPERIENCE=0.20
LINKEDIN_WEIGHT_SKILLS=0.15
LINKEDIN_WEIGHT_EDUCATION=0.10
LINKEDIN_WEIGHT_PROJECTS=0.10
LINKEDIN_WEIGHT_CERTIFICATIONS=0.05
LINKEDIN_WEIGHT_COMPLETENESS=0.15
LINKEDIN_TARGET_RECOMMENDATION_COUNT=2

# --- Skill-Gap Advisor (Module 5) ---
# Path to the JSON-backed role/skill taxonomy (relative to the backend
# project root, or absolute). Migrates to PostgreSQL later — see
# app/repositories/skill_taxonomy_repository.py.
SKILL_TAXONOMY_PATH=app/data/skill_taxonomy.json
